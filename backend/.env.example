# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use for scenario narration and decision gate
OPENAI_MODEL=gpt-4o

# Port for the Express API server
PORT=4000

# Comma-separated list of allowed CORS origins (frontend URLs)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
